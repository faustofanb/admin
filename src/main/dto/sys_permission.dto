specification SysPermissionSearchQuery {
    like/i(name)
    like/i(code)
    like/i(groupName)
}

input SysPermissionCreateCommand {
    #allScalars(this)
}

input SysPermissionUpdateCommand {
    #allScalars(this)
}

input SysPermissionView {
    #allScalars(this)
}